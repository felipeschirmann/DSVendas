# DSVendas - Homologation Environment Variables Example
# Copy this file to .env.homolog and fill in the values for the cloud environment

# Docker Registry settings
DOCKER_HUB_USERNAME=felipeschirmann
IMAGE_TAG=latest

# Database configuration (Postgres service in docker-compose)
POSTGRES_PORT=8082
POSTGRES_DB=dsvendas_homolog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password

# Spring Boot Configuration (passed to the application container)
APP_PROFILE=homolog
APP_PORT=8081

# DSVendas Application specifics (mapping to DB service inside the Docker network)
DSVENDAS_DATABASE_URL=jdbc:postgresql://db:5432/dsvendas_homolog
DSVENDAS_DATABASE_USERNAME=postgres
DSVENDAS_DATABASE_PASSWORD=postgres_secure_password
DSVENDAS_BACKEND_PORT=8080
DSVENDAS_FRONTEND_URL=http://localhost:3000
