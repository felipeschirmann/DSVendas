# DSVendas - Local Development Environment Variables Example
# Copy this file to .env.dev and fill in the values

# Database configuration
DSVENDAS_DATABASE_URL=jdbc:postgresql://localhost:5432/dsvendas
DSVENDAS_DATABASE_USERNAME=postgres
DSVENDAS_DATABASE_PASSWORD=1234567

# Port configurations
DSVENDAS_BACKEND_PORT=8080
DSVENDAS_FRONTEND_URL=http://localhost:3000

# Profile setting (optional, defaults to test if not specified, but dev is used for local postgres)
APP_PROFILE=dev
